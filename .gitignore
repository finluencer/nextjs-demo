# ─── Next.js ─────────────────────────────────────────────────────────────────
.next/          # build output (generated by next build / next dev)
out/            # static export output (generated by next export)
next-env.d.ts   # auto-generated TypeScript declarations — do not edit manually

# ─── Environment variables ────────────────────────────────────────────────────
# Never commit files that contain real secrets.
# Commit .env.local.example instead (with placeholder values).
.env.local
.env.*.local
.env.production

# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo   # TypeScript incremental compilation cache

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Testing ─────────────────────────────────────────────────────────────────
coverage/
playwright-report/
test-results/

# ─── Caches ──────────────────────────────────────────────────────────────────
.npm
.eslintcache
.turbo

# ─── IDE & editor ────────────────────────────────────────────────────────────
.idea/
.run/
.vscode/
*.swp
*.swo

# ─── OS generated ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Deployment ──────────────────────────────────────────────────────────────
.vercel

# ─── Misc ────────────────────────────────────────────────────────────────────
.claude/
*.tgz
